package wipro;

import java.util.*;
import java.util.Map;
 
public class MapExample {
public static void main(String[] args)
{
Map<Integer, String>emp = new HashMap<>();
//HashMap<Integer, String>Employee1= new HashMap<>();
 
		emp.put(101, " Vinay ");
		emp.put(102, " Sonali ");
		emp.put(103, " Renu ");
		emp.put(104, "Roshni");
		
		
		
		System.out.println(emp);
		System.out.println(emp.remove(101));
		System.out.println(emp.replace(102, "ariana"));
		System.out.println(emp.replace(103, "varun"));
		System.out.println(emp.containsKey(102));
		System.out.println(emp.get(102));
		System.out.println(emp.isEmpty());
		System.out.println(emp.containsValue("Roshni"));
 
	}
 
}
 
 
