package wipro;
import java.util.*;


public class unique_id {

	 

	  
	    	 public static void main(String[] args) {

	    	        Set<Integer> patientIds = new HashSet<>();

	    	        // Adding patients (no printing here)
	    	        patientIds.add(101);
	    	        patientIds.add(102);
	    	        patientIds.add(101); // duplicate
	    	        patientIds.add(103);

	    	        // Print after all additions
	    	        System.out.println("Registered Patient IDs:");
	    	        for (int id : patientIds) {
	    	            System.out.println(id);
	    	        }
	    	    }

	    

	    public static void addPatient(Set<Integer> patientIds, int id) {
	        if (patientIds.contains(id)) {
	            System.out.println("ID " + id + " is already registered");
	        } else {
	            patientIds.add(id);
	            System.out.println("Patient with ID " + id + " added to the system");
	        }
	    }

	    public static void viewPatients(Set<Integer> patientIds) {
	        System.out.println("\nList of unique registered patients:");
	        for (int id : patientIds) {
	            System.out.println("Patient ID: " + id);
	        }
	    }
	}



